HOST=0.0.0.0
PORT=8000
SESSION_SECRET=change-me-session-secret
APP_ENCRYPTION_KEY=change-me-encryption-key
ADMIN_USERS_FILE=data/admin_users.json
DEFAULT_REQUEST_LOGGING_ENABLED=false
DEFAULT_RESPONSE_LOGGING_ENABLED=false

# SQLite path (default storage, no extra config needed)
# SQLITE_PATH=data/llm_router.db

# MySQL — set MYSQL_URL to switch from SQLite to MySQL
# Format: mysql://user@host:port/database
# MYSQL_URL=mysql://llm_router@localhost:3306/llm_router
# MYSQL_PASSWORD=llm_router

# Redis — set REDIS_URL to enable Redis cache, queue, and distributed lock
# Format: redis://host:port/db
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# Optional table name prefix (e.g. "lr_" -> lr_api_keys, lr_request_logs, ...)
# TABLE_PREFIX=