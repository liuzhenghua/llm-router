# Set to true to enable Redis cache, Redis queue, and distributed lock
REDIS_ENABLED=false
# Set to true to use MySQL instead of SQLite (only used when DATABASE_URL is not set)
USE_MYSQL=false
HOST=0.0.0.0
PORT=8000
SESSION_SECRET=change-me-session-secret
APP_ENCRYPTION_KEY=change-me-encryption-key
ADMIN_USERS_FILE=data/admin_users.json
DEFAULT_REQUEST_LOGGING_ENABLED=false
DEFAULT_RESPONSE_LOGGING_ENABLED=false

# Optional MySQL settings (used when USE_MYSQL=true or DATABASE_URL is not set)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=llm_router
MYSQL_PASSWORD=llm_router
MYSQL_DATABASE=llm_router

# Optional Redis settings (used when REDIS_ENABLED=true)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Optional table name prefix (e.g. "lr_" -> lr_api_keys, lr_request_logs, ...)
# TABLE_PREFIX=